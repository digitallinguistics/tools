<!DOCTYPE html>
<html lang=en dir=ltr>

  <head>

    <!-- Critical Metadata -->
    <meta charset=utf-8>
    <meta name=viewport content='width=device-width, initial-scale=1, shrink-to-fit=no'>
    <title>{{title}} | Tulip</title>

    {{#block 'meta'}}

      <!-- Metadata -->
      <meta name=author content='Daniel W. Hieber'>
      <meta name=description content='Tulip (Tools for Linguistic Productivity)'>
      <meta name=generator content=Atom>
      <meta name=keywords content='Digital Linguistics, DLx, linguistics, digital humanities, language documentation, corpus linguistics, corpora, Tulip'>
      <meta name=rating content=general>
      <meta name=robots content='index,follow'>

      <!-- Linked Metadata -->
      <link rel=author href=https://danielhieber.com>
      <link rel=license href=https://github.com/digitallinguistics/tools/blob/master/LICENSE.md>

      <!-- Facebook -->
      <meta property=og:description content='A collection of tools and utilities for working with linguistic data'>
      <meta property=og:locale content=en_US>
      <meta property=og:title content='Tulip (Tools for Linguistic Productivity)'>
      <meta property=og:type content=website>
      <meta property=og:url content=https://tools.digitallinguistics.io>

      <!-- Twitter -->
      <meta name=twitter:card content='Tulip (Tools for Linguistic Productivity)'>
      <meta name=twitter:creator content=@dwhieb>

    {{/block}}

    <link rel=icon type=image/svg+xml href='{{cdn}}/img/wugbot.svg'>
    <link rel=stylesheet href=css/global.css>

    {{#block 'head'}}
    {{/block}}

  </head>

  <body>
    {{{body}}}
  </body>

</html>
